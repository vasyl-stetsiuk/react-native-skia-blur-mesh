{
  "name": "react-native-skia-blur-mesh",
  "version": "0.1.0",
  "description": "Blurred color mesh backgrounds for React Native — soft gradient effects with colored shapes and Gaussian blur. Powered by @shopify/react-native-skia.",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "build": "bob build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "clean": "rm -rf lib",
    "prepare": "bob build"
  },
  "keywords": [
    "react-native",
    "skia",
    "blur",
    "mesh",
    "gradient",
    "background",
    "blur-mesh",
    "soft-gradient",
    "aurora",
    "ios",
    "android",
    "react-native-skia"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nickstetsiuk/react-native-skia-blur-mesh.git"
  },
  "author": {
    "name": "Vasyl Stetsiuk",
    "url": "https://stetsiuk.dev"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nickstetsiuk/react-native-skia-blur-mesh/issues"
  },
  "homepage": "https://github.com/nickstetsiuk/react-native-skia-blur-mesh#readme",
  "peerDependencies": {
    "@shopify/react-native-skia": ">=1.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.71.0"
  },
  "peerDependenciesMeta": {
    "@shopify/react-native-skia": {
      "optional": false
    }
  },
  "devDependencies": {
    "@shopify/react-native-skia": "^1.11.0",
    "react": "^18.2.0",
    "react-native": "^0.75.0",
    "react-native-builder-bob": "^0.30.0",
    "typescript": "^5.4.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
